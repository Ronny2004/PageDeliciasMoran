---
// src/components/VacoChat.astro
---

<link
    href="https://cdn.jsdelivr.net/npm/@n8n/chat/dist/style.css"
    rel="stylesheet"
/>

<style is:global>
    /* =========================================
       1. ESTILOS DEL BOTÓN FLOTANTE
       ========================================= */

    /* Pone tu color de marca (Naranja) de fondo en el botón */
    .chat-window-toggle {
        background-color: #e64a19 !important; /* Tu color --accent */
    }

    /* Oculta el icono de burbuja por defecto de n8n */
    .chat-window-toggle svg {
        display: none !important;
    }

    /* Establece tu imagen de vaca como icono, ajustando el tamaño */
    .chat-window-toggle::after {
        content: "";
        display: block;
        width: 90%; /* Ajusta el tamaño del icono */
        height: 90%;
        background-image: url("/assets/iconVaco.png");
        background-size: contain;
        background-position: center;
        background-repeat: no-repeat;
    }

    /* =========================================
       2. ESTILOS DE LA CABECERA DEL CHAT
       ========================================= */

    /* Establece la imagen de Vaco como fondo de toda la cabecera */
    .chat-header {
        background-image: url("/assets/imagenChatVaco.png") !important;
        background-size: cover !important; /* Cubre toda el área */
        background-position: center !important; /* Centra la imagen */
        background-repeat: no-repeat !important;
        border-bottom: none !important; /* Elimina borde inferior */
    }

    /* Asegura que el título sea legible (blanco) */
    .chat-header h1 {
        color: #ffffff !important;
        margin: 0 !important;
    }

    /* Asegura que el subtítulo sea legible (blanco) */
    .chat-header p {
        color: #ffffff !important;
        opacity: 0.9 !important;
    }
</style>

<script type="module" is:inline>
    import { createChat } from "https://cdn.jsdelivr.net/npm/@n8n/chat/dist/chat.bundle.es.js";

    createChat({
        // URL de producción de n8n, terminando en /chat
        webhookUrl:
            "https://n8n-hh56.onrender.com/webhook/94a6404f-29aa-4ba3-a532-2271314001f7/chat",

        initialMessages: [
            "¡Hola! Soy Vaco 🐮, el asistente de Las Delicias de Morán. ¿Te provienen unas tripas o quieres hacer una reserva?",
        ],

        // Configuración de idioma y textos en español
        i18n: {
            en: {
                title: "Vaco",
                subtitle: "Asistente Virtual",
                footer: "",
                getStarted: "Iniciar chat",
                inputPlaceholder: "Escribe tu mensaje aquí...",
            },
        },
    });
</script>
