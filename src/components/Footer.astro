---
---
<footer id="contacto">
    <div class="container footer-content">
        <div class="footer-brand">
            <img
                src="/assets/logo.jpg"
                alt="Logo"
                class="footer-logo"
                style="height: 100px; margin-bottom: 20px;"
            />
            <p>Lo mejor de nuestra tierra, directo a tu mesa.</p>
        </div>
        <div class="footer-info">
            <div class="info-block">
                <i data-lucide="map-pin"></i>
                <div>
                    <h4>Ubicación</h4>
                    <p>Quito, Ecuador</p>
                    <a
                        href="https://maps.app.goo.gl/cTLAaDydFwS3eFjL8"
                        target="_blank"
                        style="color: var(--accent); text-decoration: underline;"
                    >Ver en Google Maps</a>
                </div>
            </div>
            <div class="info-block">
                <i data-lucide="clock"></i>
                <div>
                    <h4>Horarios</h4>
                    <p>Lunes a Sábados: 3:00 PM - 10:00 PM</p>
                </div>
            </div>
            <div class="info-block">
                <i data-lucide="phone"></i>
                <div>
                    <h4>Teléfono</h4>
                    <p>099 552 6145</p>
                </div>
            </div>
        </div>
        <div class="footer-cta">
            <a
                href="https://chat.whatsapp.com/BV0eiC6HClm6UeEPX5Fkq7"
                target="_blank"
                rel="noopener noreferrer"
                class="btn btn-primary large-btn"
            >Haz tu Pedido por WhatsApp</a>
            <a
                href="https://maps.app.goo.gl/cTLAaDydFwS3eFjL8"
                target="_blank"
                class="btn btn-outline">Cómo Llegar</a>
        </div>
    </div>
    <div class="footer-bottom">
        <p>
            &copy; 2026 Las Delicias de Morán. Todos los derechos
            reservados.
        </p>
        <p class="developer-credit">
            Desarrollado por <strong>Equipo DM</strong> |
            <a href="mailto:ronnypallo8@gmail.com">ronnypallo8@gmail.com</a>
        </p>
        <div class="employee-portal">
            <a
                href="https://restaurant-crm-two.vercel.app"
                target="_blank"
            >
                <i data-lucide="lock" style="width: 14px; height: 14px;"></i> Acceso Empleados
            </a>
        </div>
    </div>
</footer>

<style>
footer {
    background-color: var(--primary-dark);
    color: var(--white);
    padding: 5rem 0 2rem 0;
}

.footer-content {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 3rem;
    align-items: flex-start;
}

.footer-brand h2 {
    font-size: 2rem;
    margin-bottom: 1rem;
}

.footer-info {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
}

.info-block {
    display: flex;
    gap: 1rem;
}

.info-block i {
    color: var(--accent);
}

.info-block h4 {
    margin-bottom: 0.2rem;
}

.footer-cta {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    animation: fadeInUp 0.8s ease 0.4s both;
}

.large-btn {
    text-align: center;
    padding: 1.2rem;
    font-size: 1.1rem;
}

.footer-bottom {
    text-align: center;
    margin-top: 5rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    font-size: 0.8rem;
    opacity: 0.6;
}

.developer-credit {
    margin-top: 0.5rem;
    font-size: 0.75rem;
    opacity: 0.8;
}

.developer-credit a {
    color: var(--accent);
    text-decoration: underline;
}

.developer-credit a:hover {
    color: var(--white);
}

.employee-portal {
    margin-top: 2rem;
    opacity: 0.4;
    font-size: 0.7rem;
    transition: opacity 0.3s ease;
}

.employee-portal:hover {
    opacity: 1;
}

.employee-portal a {
    color: var(--white);
    text-decoration: none;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 5px;
}

@media (max-width: 992px) {
    .footer-content {
        grid-template-columns: 1fr;
    }
}
</style>
